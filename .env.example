# Copy to .env and fill in values. Do not commit .env.

# LLM_BACKEND=gemini  (default)  or  openai_compatible  (local Ollama, LM Studio, etc.)

# --- Google Gemini (when LLM_BACKEND is gemini or unset)
GEMINI_API_KEY=
GEMINI_MODEL=

# --- OpenAI-compatible API (when LLM_BACKEND=openai_compatible)
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_COMPATIBLE_MODEL=qwen3
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_JSON_MODE=true

# Optional (all backends)
# LLM_TIMEOUT_MS=120000
# PORT=8000
# ENABLE_AI_PREVIEW=true
# PLAN_API_TOKEN=
